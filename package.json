{
  "name": "print-center",
  "version": "1.0.0",
  "description": "Web-based print & scan management for CUPS printers on NAS",
  "private": true,
  "scripts": {
    "dev:server": "MOCK_MODE=true tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev:client:nas": "API_TARGET=http://nas.local:3100 vite",
    "dev": "MOCK_MODE=true concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "docker:build": "docker build -t print-center .",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "multer": "^1.4.5-lts.1",
    "better-sqlite3": "^11.0.0",
    "ipp": "^2.0.1",
    "sharp": "^0.33.0",
    "pdf-lib": "^1.17.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/multer": "^1.4.12",
    "@types/better-sqlite3": "^7.6.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vite": "^5.4.0",
    "concurrently": "^9.0.0",
    "lucide-react": "^0.460.0",
    "react-hot-toast": "^2.4.1",
    "react-dropzone": "^14.3.0",
    "pdfjs-dist": "^4.7.76"
  }
}
